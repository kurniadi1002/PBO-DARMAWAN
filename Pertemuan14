    // Fungsi 1: Hitung Total Harga
private void hitungTotal() {
    String pilihan = jTextField1.getText().trim();
    int harga = 0;

    switch (pilihan) {
        case "1": harga = 10000; break;
        case "2": harga = 12500; break;
        case "3": harga = 15000; break;
        case "4": harga = 17500; break;
        default: 
            jTextField2.setText("Paket Salah");
            return;
        }

    if (jTextField5.getText().trim().isEmpty()) {
        return;
    }

    int jumlah = Integer.parseInt(jTextField5.getText().trim());
    int totalAwal = harga * jumlah;
    int totalAkhir = totalAwal;

    if (totalAwal > 50000) {
        totalAkhir = (int) (totalAwal * 0.9); 
    }

    jTextField2.setText(String.valueOf(totalAkhir));
    
    if (!jTextField3.getText().trim().isEmpty()) {
        hitungKembali();
    }
}

// Fungsi 2: Hitung Kembalian
private void hitungKembali() {
    if (jTextField2.getText().trim().isEmpty() || jTextField3.getText().trim().isEmpty()) {
        return;
    }

    int total = Integer.parseInt(jTextField2.getText().trim());
    int bayar = Integer.parseInt(jTextField3.getText().trim());
    int kembali = bayar - total;

    if (kembali < 0) {
        jTextField4.setText("Uang Kurang");
    } else {
        jTextField4.setText(String.valueOf(kembali));
    }
}

